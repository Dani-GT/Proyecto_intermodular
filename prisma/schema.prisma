// Prisma Schema - Club Béisbol Granollers
// Configurado para PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum TipoRol {
  SOCIO
  JUGADOR
  TECNICO
  ADMIN
}

enum NombreCategoria {
  SUB10
  SUB12
  SUB14
  SUB16
  SUB18
  SENIOR
}

enum EstadoInscripcion {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum EstadoCompra {
  PENDIENTE
  PAGADA
  COMPLETADA
  CANCELADA
  ENVIADA
}

enum CategoriaProducto {
  ROPA
  EQUIPAMIENTO
  MERCHANDISING
}

// ─── MODELOS ─────────────────────────────────────────────────────────────────

model Persona {
  id              Int           @id @default(autoincrement())
  nombre          String        @db.VarChar(100)
  apellidos       String        @db.VarChar(100)
  email           String        @unique @db.VarChar(255)
  password        String        @db.VarChar(255)
  fechaNacimiento DateTime?
  telefono        String?       @db.VarChar(20)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relaciones
  rol           Rol?
  compras       Compra[]
  inscripciones Inscripcion[]

  @@map("personas")
}

model Rol {
  id        Int      @id @default(autoincrement())
  tipo      TipoRol  @default(SOCIO)
  personaId Int      @unique
  createdAt DateTime @default(now())

  persona Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@map("roles")
}

model Categoria {
  id                   Int             @id @default(autoincrement())
  nombre               NombreCategoria @unique
  descripcion          String?         @db.Text
  entrenador           String?         @db.VarChar(100)
  horarioEntrenamiento String?         @db.VarChar(200)
  createdAt            DateTime        @default(now())

  inscripciones Inscripcion[]
  partidos      Partido[]

  @@map("categorias")
}

model Inscripcion {
  id             Int               @id @default(autoincrement())
  personaId      Int
  categoriaId    Int
  estado         EstadoInscripcion @default(PENDIENTE)
  rolSolicitado  TipoRol           @default(JUGADOR)
  temporada      String            @db.VarChar(10)
  notas          String?           @db.Text
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  persona    Persona     @relation(fields: [personaId], references: [id], onDelete: Cascade)
  categoria  Categoria   @relation(fields: [categoriaId], references: [id])
  tutorLegal TutorLegal?

  @@unique([personaId, categoriaId, temporada])
  @@map("inscripciones")
}

model TutorLegal {
  id            Int         @id @default(autoincrement())
  inscripcionId Int         @unique
  nombre        String      @db.VarChar(100)
  apellidos     String      @db.VarChar(100)
  dni           String      @db.VarChar(20)
  createdAt     DateTime    @default(now())

  inscripcion Inscripcion @relation(fields: [inscripcionId], references: [id], onDelete: Cascade)

  @@map("tutores_legales")
}

model Partido {
  id          Int       @id @default(autoincrement())
  rival       String    @db.VarChar(100)
  fecha       DateTime
  campo       String?   @db.VarChar(200)
  esLocal     Boolean   @default(true)
  resultado   String?   @db.VarChar(20)
  descripcion String?   @db.Text
  categoriaId Int
  createdAt   DateTime  @default(now())

  categoria Categoria @relation(fields: [categoriaId], references: [id])

  @@map("partidos")
}

model Noticia {
  id          Int      @id @default(autoincrement())
  titulo      String   @unique @db.VarChar(255)
  resumen     String?  @db.VarChar(500)
  contenido   String   @db.Text
  imagen      String?  @db.VarChar(500)
  autor       String?  @db.VarChar(100)
  publicadoEn DateTime @default(now())
  destacada   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("noticias")
}

model Producto {
  id          Int               @id @default(autoincrement())
  nombre      String            @unique @db.VarChar(255)
  descripcion String?           @db.Text
  precio      Decimal           @db.Decimal(10, 2)
  stock       Int               @default(0)
  imagen      String?           @db.VarChar(500)
  categoria   CategoriaProducto @default(MERCHANDISING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  CompraProducto CompraProducto[]

  @@map("productos")
}

model Compra {
  id        String       @id @default(uuid())
  personaId Int
  total     Decimal      @db.Decimal(10, 2)
  estado    EstadoCompra @default(PENDIENTE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  persona        Persona          @relation(fields: [personaId], references: [id])
  CompraProducto CompraProducto[]

  @@map("compras")
}

model CompraProducto {
  id         Int     @id @default(autoincrement())
  compraId   String
  productoId Int
  cantidad   Int     @default(1)
  precioUnit Decimal @db.Decimal(10, 2)

  compra   Compra   @relation(fields: [compraId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])

  @@map("compra_productos")
}
