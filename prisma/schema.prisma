// Prisma Schema - Club Béisbol Granollers
// Configurado para PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum TipoRol {
  SOCIO
  JUGADOR
  TECNICO
  ADMIN
}

enum NombreCategoria {
  SUB10
  SUB12
  SUB14
  SUB16
  SUB18
  SENIOR
}

enum EstadoInscripcion {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum EstadoCompra {
  PENDIENTE
  PAGADA
  CANCELADA
  ENVIADA
}

enum CategoriaProducto {
  UNIFORME
  EQUIPAMIENTO
  ACCESORIO
  OTRO
}

// ─── MODELOS ─────────────────────────────────────────────────────────────────

model Persona {
  id              Int           @id @default(autoincrement())
  nombre          String        @db.VarChar(100)
  apellidos       String        @db.VarChar(100)
  email           String        @unique @db.VarChar(255)
  password        String        @db.VarChar(255)
  fechaNacimiento DateTime?
  telefono        String?       @db.VarChar(20)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relaciones
  rol             Rol?
  compras         Compra[]
  inscripciones   Inscripcion[]
  noticias        Noticia[]
  tutor           MadrePadre?   @relation("TutorDePersona")
  tutorId         Int?
  tutorLegal      MadrePadre?   @relation("PersonaTutorLegal", fields: [tutorId], references: [id])

  @@map("personas")
}

model MadrePadre {
  id        Int      @id @default(autoincrement())
  nombre    String   @db.VarChar(100)
  apellidos String   @db.VarChar(100)
  email     String   @db.VarChar(255)
  telefono  String   @db.VarChar(20)
  createdAt DateTime @default(now())

  // Relaciones
  hijos     Persona[] @relation("PersonaTutorLegal")
  persona   Persona?  @relation("TutorDePersona")

  @@map("madres_padres")
}

model Rol {
  id        Int      @id @default(autoincrement())
  tipo      TipoRol  @default(SOCIO)
  personaId Int      @unique
  createdAt DateTime @default(now())

  // Relaciones
  persona   Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@map("roles")
}

model Categoria {
  id          Int             @id @default(autoincrement())
  nombre      NombreCategoria @unique
  descripcion String?         @db.Text
  edadMin     Int?
  edadMax     Int?
  activa      Boolean         @default(true)

  // Relaciones
  inscripciones Inscripcion[]
  partidos      Partido[]

  @@map("categorias")
}

model Inscripcion {
  id           Int               @id @default(autoincrement())
  personaId    Int
  categoriaId  Int
  estado       EstadoInscripcion @default(PENDIENTE)
  temporada    String            @db.VarChar(10) // Ej: "2025-2026"
  notas        String?           @db.Text
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  // Relaciones
  persona      Persona           @relation(fields: [personaId], references: [id], onDelete: Cascade)
  categoria    Categoria         @relation(fields: [categoriaId], references: [id])

  @@unique([personaId, categoriaId, temporada])
  @@map("inscripciones")
}

model Partido {
  id          Int       @id @default(autoincrement())
  rival       String    @db.VarChar(100)
  fecha       DateTime
  lugar       String    @db.VarChar(200)
  esLocal     Boolean   @default(true)
  golesFavor  Int?
  golesContra Int?
  finalizado  Boolean   @default(false)
  categoriaId Int
  createdAt   DateTime  @default(now())

  // Relaciones
  categoria   Categoria @relation(fields: [categoriaId], references: [id])

  @@map("partidos")
}

model Noticia {
  id          Int      @id @default(autoincrement())
  titulo      String   @db.VarChar(255)
  contenido   String   @db.Text
  imagen      String?  @db.VarChar(500)
  publicada   Boolean  @default(false)
  autorId     Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  autor       Persona  @relation(fields: [autorId], references: [id])

  @@map("noticias")
}

model Producto {
  id          Int               @id @default(autoincrement())
  nombre      String            @db.VarChar(255)
  descripcion String?           @db.Text
  precio      Decimal           @db.Decimal(10, 2)
  stock       Int               @default(0)
  imagen      String?           @db.VarChar(500)
  categoria   CategoriaProducto @default(OTRO)
  activo      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relaciones
  compraItems CompraProducto[]

  @@map("productos")
}

model Compra {
  id        Int          @id @default(autoincrement())
  personaId Int
  total     Decimal      @db.Decimal(10, 2)
  estado    EstadoCompra @default(PENDIENTE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Relaciones
  persona   Persona        @relation(fields: [personaId], references: [id])
  items     CompraProducto[]

  @@map("compras")
}

model CompraProducto {
  id         Int     @id @default(autoincrement())
  compraId   Int
  productoId Int
  cantidad   Int     @default(1)
  precioUnit Decimal @db.Decimal(10, 2)

  // Relaciones
  compra     Compra   @relation(fields: [compraId], references: [id], onDelete: Cascade)
  producto   Producto @relation(fields: [productoId], references: [id])

  @@map("compra_productos")
}
