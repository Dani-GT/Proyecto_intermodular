<%- include('../partials/head', { title: 'Tienda oficial' }) %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="page-header">
  <div class="container">
    <div class="breadcrumb">
      <a href="/">Inicio</a><span class="breadcrumb-sep">›</span><span>Tienda</span>
    </div>
    <h1 class="page-header-title">Tienda oficial</h1>
    <p class="page-header-desc">Equipamiento y merchandising oficial del Club Béisbol Granollers.</p>
  </div>
</div>

<main>
  <div class="container section-py">
    <div class="shop-layout">

      <!-- Sidebar filtros -->
      <aside class="shop-sidebar">
        <div class="card" style="padding:1.25rem">
          <div class="shop-sidebar-section">
            <p class="shop-sidebar-title">Categoría</p>
            <button class="shop-filter-btn active" data-cat="TODOS">Todos los productos</button>
            <button class="shop-filter-btn" data-cat="ROPA">👕 Ropa</button>
            <button class="shop-filter-btn" data-cat="EQUIPAMIENTO">⚾ Equipamiento</button>
            <button class="shop-filter-btn" data-cat="MERCHANDISING">🎁 Merchandising</button>
          </div>
          <div class="shop-sidebar-section">
            <p class="shop-sidebar-title">Carrito</p>
            <a href="/tienda/carrito" class="btn btn-outline btn-sm btn-full">🛒 Ver carrito</a>
          </div>
          <div class="shop-sidebar-section" style="margin-bottom:0">
            <p class="shop-sidebar-title">Pagos seguros</p>
            <p style="font-size:.8rem;color:var(--text3)">🔒 Transacciones cifradas · Devoluciones en 30 días</p>
          </div>
        </div>
      </aside>

      <!-- Productos -->
      <div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:1rem">
          <p style="font-size:.9rem;color:var(--text2)">
            <strong style="color:var(--text)"><%= typeof productos !== 'undefined' ? productos.length : 0 %></strong> productos
          </p>
        </div>

        <% if (typeof productos !== 'undefined' && productos && productos.length > 0) { %>
          <div class="products-grid">
            <% productos.forEach(function(producto) { %>
              <div class="product-card-wrap" data-cat="<%= producto.categoria %>">
                <a href="/tienda/<%= producto.id %>" class="card product-card card-hover" style="text-decoration:none;display:block">
                  <div class="product-img">
                    <% if (producto.imagen) { %>
                      <img src="<%= producto.imagen %>" alt="<%= producto.nombre %>" class="img-zoomable" data-src="<%= producto.imagen %>" data-title="<%= producto.nombre %>" style="cursor:zoom-in">
                    <% } else { %>
                      <div class="product-img-placeholder">
                        <%= producto.categoria === 'ROPA' ? '👕' : producto.categoria === 'EQUIPAMIENTO' ? '⚾' : '🎁' %>
                      </div>
                    <% } %>
                    <% if (producto.stock === 0) { %>
                      <div style="position:absolute;inset:0;background:rgba(0,0,0,.6);display:flex;align-items:center;justify-content:center">
                        <span class="badge badge-danger">Agotado</span>
                      </div>
                    <% } %>
                  </div>
                  <div class="product-body">
                    <p class="product-cat"><%= producto.categoria %></p>
                    <h3 class="product-name"><%= producto.nombre %></h3>
                    <div class="product-price-row">
                      <span class="product-price"><%= Number(producto.precio).toFixed(2) %> €</span>
                      <% if (producto.stock > 0) { %>
                        <form action="/tienda/carrito/agregar" method="POST" onclick="event.stopPropagation()">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <input type="hidden" name="productoId" value="<%= producto.id %>">
                          <input type="hidden" name="cantidad" value="1">
                          <button type="submit" class="product-add" title="Añadir al carrito">+</button>
                        </form>
                      <% } %>
                    </div>
                  </div>
                </a>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="card" style="padding:4rem;text-align:center">
            <div style="font-size:3rem;margin-bottom:1rem">🛍️</div>
            <h3 style="margin-bottom:.5rem">Sin productos disponibles</h3>
            <p style="color:var(--text2)">Próximamente nuevos artículos en la tienda.</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</main>

<!-- ── Modal imagen producto ───────────────────────────────── -->
<div id="imgModal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.85);align-items:center;justify-content:center;padding:1.5rem" onclick="cerrarModal(event)">
  <div style="position:relative;max-width:90vw;max-height:90vh" onclick="event.stopPropagation()">
    <button onclick="document.getElementById('imgModal').style.display='none'" style="position:absolute;top:-14px;right:-14px;width:32px;height:32px;border-radius:50%;background:#fff;border:none;font-size:1.1rem;cursor:pointer;line-height:1;z-index:1">✕</button>
    <img id="imgModalSrc" src="" alt="" style="max-width:90vw;max-height:85vh;object-fit:contain;border-radius:8px;display:block">
    <p id="imgModalTitle" style="color:#fff;text-align:center;margin-top:.75rem;font-size:.95rem;font-weight:600"></p>
  </div>
</div>

<script>
  document.querySelectorAll('.img-zoomable').forEach(img => {
    img.addEventListener('click', function(e) {
      e.preventDefault(); e.stopPropagation();
      document.getElementById('imgModalSrc').src   = this.dataset.src;
      document.getElementById('imgModalTitle').textContent = this.dataset.title || '';
      const modal = document.getElementById('imgModal');
      modal.style.display = 'flex';
    });
  });
  function cerrarModal(e) {
    if (e.target.id === 'imgModal') document.getElementById('imgModal').style.display = 'none';
  }
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') document.getElementById('imgModal').style.display = 'none';
  });
</script>

<%- include('../partials/footer') %>
