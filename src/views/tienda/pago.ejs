<%- include('../partials/head', { title: 'Pago seguro' }) %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="page-header">
  <div class="container">
    <div class="breadcrumb">
      <a href="/tienda">Tienda</a><span class="breadcrumb-sep">›</span>
      <a href="/tienda/carrito">Carrito</a><span class="breadcrumb-sep">›</span>
      <a href="/tienda/checkout">Confirmar</a><span class="breadcrumb-sep">›</span>
      <span>Pago</span>
    </div>
    <h1 class="page-header-title">Pago seguro</h1>
    <p class="page-header-desc">Introduce los datos de tu tarjeta para completar el pedido.</p>
  </div>
</div>

<main>
  <div class="container section-py">
    <div style="display:grid;grid-template-columns:1fr 340px;gap:2rem;align-items:start;max-width:900px;margin:0 auto">

      <!-- Formulario de tarjeta (MOCK) -->
      <div class="card" style="padding:2rem">
        <!-- Aviso simulación -->
        <div style="background:rgba(234,179,8,.08);border:1px solid rgba(234,179,8,.3);border-radius:var(--radius);padding:.875rem 1rem;margin-bottom:1.75rem;display:flex;gap:.75rem;align-items:flex-start">
          <span style="font-size:1.2rem">🧪</span>
          <div>
            <strong style="font-size:.88rem">Entorno de pruebas</strong>
            <p style="font-size:.8rem;color:var(--text2);margin:.2rem 0 0">Este es un pago simulado. No se realizará ningún cargo real. Usa cualquier número de tarjeta.</p>
          </div>
        </div>

        <h3 style="margin-bottom:1.5rem;display:flex;align-items:center;gap:.5rem">
          💳 Datos de la tarjeta
        </h3>

        <form action="/tienda/pago" method="POST" id="form-pago">
          <div class="form-group">
            <label class="form-label">Nombre del titular</label>
            <input type="text" class="form-control" placeholder="Nombre Apellidos"
              value="<%= usuario ? usuario.nombre + ' ' + usuario.apellidos : '' %>"
              required>
          </div>

          <div class="form-group">
            <label class="form-label">Número de tarjeta</label>
            <div style="position:relative">
              <input type="text" class="form-control" id="card-number"
                placeholder="0000 0000 0000 0000" maxlength="19"
                style="padding-right:3rem;letter-spacing:.1em" required>
              <span style="position:absolute;right:.875rem;top:50%;transform:translateY(-50%);font-size:1.3rem" id="card-icon">💳</span>
            </div>
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
            <div class="form-group" style="margin-bottom:0">
              <label class="form-label">Fecha de expiración</label>
              <input type="text" class="form-control" placeholder="MM/AA" maxlength="5" required>
            </div>
            <div class="form-group" style="margin-bottom:0">
              <label class="form-label">CVV</label>
              <input type="text" class="form-control" placeholder="•••" maxlength="4" required>
            </div>
          </div>

          <button type="submit" class="btn btn-primary btn-full btn-lg" style="margin-top:1.75rem" id="btn-pagar">
            🔒 Pagar <%= total %> € ahora
          </button>
        </form>

        <div style="display:flex;align-items:center;justify-content:center;gap:.75rem;margin-top:1.25rem">
          <span style="font-size:.75rem;color:var(--text3)">Pago cifrado SSL</span>
          <span style="color:var(--border)">·</span>
          <span style="font-size:.75rem;color:var(--text3)">🔒 Secure Checkout</span>
        </div>
      </div>

      <!-- Resumen pedido -->
      <div>
        <div class="cart-summary">
          <h3 style="margin-bottom:1.25rem">Tu pedido</h3>

          <% items.forEach(function(item) { %>
            <div style="display:flex;justify-content:space-between;align-items:center;padding:.5rem 0;border-bottom:1px solid var(--border);gap:.5rem">
              <div style="min-width:0">
                <p style="font-size:.85rem;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= item.producto.nombre %></p>
                <p style="font-size:.75rem;color:var(--text3)">× <%= item.cantidad %></p>
              </div>
              <span style="font-size:.9rem;font-weight:600;flex-shrink:0"><%= (Number(item.producto.precio) * item.cantidad).toFixed(2) %> €</span>
            </div>
          <% }) %>

          <div class="cart-summary-row" style="margin-top:.75rem">
            <span style="color:var(--text2)">Envío</span>
            <span style="color:#22c55e">Gratis</span>
          </div>
          <div class="cart-summary-row" style="padding-top:.875rem;margin-top:.5rem;border-top:1px solid var(--border)">
            <strong>Total</strong>
            <strong style="font-size:1.2rem;color:var(--accent)"><%= total %> €</strong>
          </div>

          <% if (typeof direccion !== 'undefined' && direccion) { %>
            <div style="margin-top:1rem;padding:.75rem;background:var(--bg2);border-radius:var(--radius-sm);font-size:.82rem;color:var(--text2)">
              📦 Entrega en: <strong style="color:var(--text)"><%= direccion %></strong>
            </div>
          <% } %>
        </div>
      </div>

    </div>
  </div>
</main>

<script>
  // Formatear número de tarjeta con espacios
  document.getElementById('card-number').addEventListener('input', function(e) {
    let val = e.target.value.replace(/\D/g,'').substring(0,16);
    e.target.value = val.replace(/(.{4})/g,'$1 ').trim();
    // Cambiar icono según tipo
    const icon = document.getElementById('card-icon');
    if (val.startsWith('4')) icon.textContent = '💳';
    else if (val.startsWith('5')) icon.textContent = '💳';
    else if (val.startsWith('3')) icon.textContent = '💳';
    else icon.textContent = '💳';
  });

  // Simular loading al pagar
  document.getElementById('form-pago').addEventListener('submit', function(e) {
    const btn = document.getElementById('btn-pagar');
    btn.disabled = true;
    btn.innerHTML = '<span style="display:inline-flex;align-items:center;gap:.5rem"><svg style="animation:spin 1s linear infinite;width:18px;height:18px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg> Procesando pago…</span>';
  });
</script>
<style>
  @keyframes spin { to { transform: rotate(360deg); } }
</style>

<%- include('../partials/footer') %>
