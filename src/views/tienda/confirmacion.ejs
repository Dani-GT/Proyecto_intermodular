<%- include('../partials/head', { title: 'Pedido confirmado' }) %>
<%- include('../partials/navbar') %>

<main style="min-height:calc(100vh - var(--nav-h));display:flex;align-items:center">
  <div class="container text-center" style="padding:4rem 0">
    <div style="width:80px;height:80px;border-radius:50%;background:rgba(34,197,94,.15);border:2px solid rgba(34,197,94,.3);display:flex;align-items:center;justify-content:center;font-size:2.5rem;margin:0 auto 1.5rem">
      ✅
    </div>
    <h1 style="font-size:2rem;margin-bottom:.75rem">¡Pedido confirmado!</h1>
    <p style="color:var(--text2);max-width:420px;margin:0 auto 2rem;font-size:1rem;line-height:1.7">
      Tu pedido ha sido procesado correctamente. Recibirás un email de confirmación con los detalles.
    </p>
    <% if (typeof compra !== 'undefined' && compra) { %>
      <div class="card" style="padding:1.5rem;max-width:360px;margin:0 auto 2rem">
        <p style="font-size:.8rem;color:var(--text3);margin-bottom:.5rem">Número de pedido</p>
        <code style="font-size:1rem;color:var(--accent)">#<%= compra.id.substring(0,8).toUpperCase() %></code>
      </div>
    <% } %>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
      <a href="/tienda" class="btn btn-primary btn-lg">Seguir comprando</a>
      <a href="/auth/perfil" class="btn btn-outline btn-lg">Ver mis pedidos</a>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
