<%- include('partials/head', { title: 'Contacto' }) %>
<%- include('partials/navbar') %>
<%- include('partials/flash') %>

<div class="page-header">
  <div class="container">
    <div class="breadcrumb">
      <a href="/">Inicio</a><span class="breadcrumb-sep">›</span><span>Contacto</span>
    </div>
    <h1 class="page-header-title">Contacta con el club</h1>
    <p class="page-header-desc">¿Tienes alguna pregunta? Estamos aquí para ayudarte.</p>
  </div>
</div>

<main>
  <div class="container section-py">
    <div class="contact-grid">

      <!-- Info -->
      <div class="contact-info">
        <div class="contact-item">
          <div class="contact-icon">📍</div>
          <div>
            <p class="contact-label">Dirección</p>
            <p class="contact-value">Carrer del Diamant, s/n<br>08400 Granollers, Barcelona</p>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-icon">📞</div>
          <div>
            <p class="contact-label">Teléfono</p>
            <p class="contact-value"><a href="tel:+34930000000" style="color:var(--text)">+34 93 000 00 00</a></p>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-icon">✉️</div>
          <div>
            <p class="contact-label">Email</p>
            <p class="contact-value"><a href="mailto:info@cbgranollers.cat" style="color:var(--text)">info@cbgranollers.cat</a></p>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-icon">🕐</div>
          <div>
            <p class="contact-label">Horario de atención</p>
            <p class="contact-value">Lunes a Viernes: 17:00 – 21:00<br>Sábados y Domingos: 10:00 – 14:00</p>
          </div>
        </div>

        <!-- Redes sociales -->
        <div>
          <p class="contact-label" style="margin-bottom:.75rem">Síguenos en redes</p>
          <div style="display:flex;gap:.75rem">
            <a href="#" class="btn btn-outline btn-sm">📸 Instagram</a>
            <a href="#" class="btn btn-outline btn-sm">📘 Facebook</a>
            <a href="#" class="btn btn-outline btn-sm">🐦 Twitter</a>
          </div>
        </div>
      </div>

      <!-- Formulario -->
      <div>
        <div class="card" style="padding:2rem">
          <h3 style="margin-bottom:1.5rem">Envíanos un mensaje</h3>
          <form action="/contacto" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
              <div class="form-group">
                <label class="form-label">Nombre <span style="color:red">*</span></label>
                <input type="text" name="nombre" class="form-control" placeholder="Tu nombre" required>
              </div>
              <div class="form-group">
                <label class="form-label">Email <span style="color:red">*</span></label>
                <input type="email" name="email" class="form-control" placeholder="tu@email.com" required>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Asunto</label>
              <select name="asunto" class="form-control">
                <option value="">Selecciona un asunto…</option>
                <option>Información sobre inscripciones</option>
                <option>Cuotas y pagos</option>
                <option>Información general</option>
                <option>Otros</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Mensaje <span style="color:red">*</span></label>
              <textarea name="mensaje" class="form-control" rows="5" placeholder="Escribe tu mensaje aquí…" style="resize:vertical" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-full">Enviar mensaje</button>
          </form>
        </div>
      </div>

    </div>
  </div>
</main>

<%- include('partials/footer') %>
