<%- include('partials/head', { title: 'El Club' }) %>
  <%- include('partials/navbar') %>
    <%- include('partials/flash') %>

      <!-- ══════════ HERO ══════════ -->
      <section class="club-hero">
        <div class="club-hero-bg"></div>
        <div class="club-hero-overlay"></div>
        <div class="container club-hero-content">
          <div class="hero-eyebrow">🏟️ Est. 1985 · Granollers</div>
          <h1 class="club-hero-title">Un siglo de <span>excelencia</span></h1>
          <p class="club-hero-desc">Más de 35 años formando campeones dentro y fuera del campo. Conoce nuestra historia,
            nuestros valores y la familia que hemos construido.</p>
        </div>
      </section>

      <!-- ══════════ STATS ══════════ -->
      <section class="section-py">
        <div class="container">
          <div class="club-stats">
            <div class="club-stat-item">
              <div class="club-stat-num">+110</div>
              <div class="club-stat-label">Jugadores federados</div>
            </div>
            <div class="club-stat-item">
              <div class="club-stat-num">+20</div>
              <div class="club-stat-label">Títulos conquistados</div>
            </div>
            <div class="club-stat-item">
              <div class="club-stat-num">1985</div>
              <div class="club-stat-label">Año de fundación</div>
            </div>
            <div class="club-stat-item">
              <div class="club-stat-num">8</div>
              <div class="club-stat-label">Equipos en competición</div>
            </div>
          </div>
        </div>
      </section>

      <!-- ══════════ MISIÓN Y VALORES ══════════ -->
      <section class="section-py" style="background:var(--bg2)">
        <div class="container">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center">
            <div>
              <div class="section-label">Quiénes somos</div>
              <h2 class="section-title" style="margin-bottom:1.25rem">Nuestra misión</h2>
              <p style="color:var(--text2);line-height:1.8;margin-bottom:1rem">El Club Béisbol Granollers nació en 1985
                con una misión clara: convertir el béisbol en parte del tejido cultural de nuestra ciudad. Hoy, con más
                de 35 años de historia, somos uno de los clubes de béisbol más importantes de Cataluña.</p>
              <p style="color:var(--text2);line-height:1.8">Formamos jugadores y personas. El béisbol nos enseña
                disciplina, trabajo en equipo y perseverancia — valores que nuestros jugadores llevan toda la vida.</p>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
              <div class="card" style="padding:1.5rem;text-align:center">
                <div style="font-size:2rem;margin-bottom:.5rem">🏅</div>
                <h4 style="margin-bottom:.4rem">Excelencia</h4>
                <p style="font-size:.82rem;color:var(--text2)">Buscamos la mejora continua en cada entrenamiento y
                  competición.</p>
              </div>
              <div class="card" style="padding:1.5rem;text-align:center">
                <div style="font-size:2rem;margin-bottom:.5rem">🤝</div>
                <h4 style="margin-bottom:.4rem">Equipo</h4>
                <p style="font-size:.82rem;color:var(--text2)">Ganamos y perdemos juntos. La unidad es nuestra mayor
                  fortaleza.</p>
              </div>
              <div class="card" style="padding:1.5rem;text-align:center">
                <div style="font-size:2rem;margin-bottom:.5rem">🌱</div>
                <h4 style="margin-bottom:.4rem">Formación</h4>
                <p style="font-size:.82rem;color:var(--text2)">Invertimos en el desarrollo de los jóvenes deportistas.
                </p>
              </div>
              <div class="card" style="padding:1.5rem;text-align:center">
                <div style="font-size:2rem;margin-bottom:.5rem">❤️</div>
                <h4 style="margin-bottom:.4rem">Pasión</h4>
                <p style="font-size:.82rem;color:var(--text2)">El amor por el béisbol es lo que nos mueve cada día.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ══════════ TIMELINE ══════════ -->
      <section class="section-py">
        <div class="container">
          <div class="text-center" style="margin-bottom:3rem">
            <div class="section-label">Historia</div>
            <h2 class="section-title">Nuestro camino a través del tiempo</h2>
          </div>
          <div style="max-width:700px;margin:0 auto">
            <div class="timeline">
              <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-year">1985 · Los comienzos</div>
                <h3 class="timeline-title">Fundación del club</h3>
                <p class="timeline-desc">Un grupo de apasionados del béisbol funda el club en Granollers con el objetivo
                  de introducir este deporte en la ciudad. Los primeros entrenamientos se realizan en el parque
                  municipal.</p>
                <div class="timeline-img" style="overflow:hidden">
                  <img src="/images/estreno1985.webp" alt="Fundación del club 1985" style="width:100%;height:100%;object-fit:cover">
                </div>
              </div>
              <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-year">1992 · Primera victoria</div>
                <h3 class="timeline-title">Primer título regional</h3>
                <p class="timeline-desc">El equipo senior conquista su primer Campeonato Regional de Cataluña, poniendo
                  a Granollers en el mapa del béisbol español.</p>
              </div>
              <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-year">2001 · Nuevas instalaciones</div>
                <h3 class="timeline-title">Campo municipal propio</h3>
                <p class="timeline-desc">El Ayuntamiento de Granollers cede el campo municipal para uso exclusivo del
                  club. Una instalación de referencia que permite crecer en jugadores y equipos.</p>
              </div>
              <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-year">2010 · Expansión</div>
                <h3 class="timeline-title">Escuela base consolidada</h3>
                <p class="timeline-desc">Se crean las seis categorías base (Sub10 a Sub18), permitiendo que niños desde
                  los 8 años comiencen su formación en el club.</p>
              </div>
              <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-year">2026 · Presente</div>
                <h3 class="timeline-title">Temporada más ambiciosa</h3>
                <p class="timeline-desc">Con más de 110 jugadores federados y 8 equipos en competición, el club afronta
                  la temporada más ambiciosa de su historia aspirando al ascenso a la División de Honor nacional.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ══════════ CUERPO TÉCNICO ══════════ -->
      <section class="section-py" style="background:var(--bg2)">
        <div class="container">
          <div class="text-center" style="margin-bottom:3rem">
            <div class="section-label">Equipo humano</div>
            <h2 class="section-title">Cuerpo técnico</h2>
          </div>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem">
            <% var tecnicos = [{nombre:'Roberto Fuentes',cargo:'Entrenador S\u00e9nior',desc:'Ex jugador de la liga nacional con 15 a\u00f1os de experiencia en b\u00e9isbol de alto rendimiento.'},{nombre:'\u00c0lex Ribera',cargo:'Entrenador Sub18',desc:'Especialista en desarrollo juvenil y preparaci\u00f3n para el salto al b\u00e9isbol adulto.'},{nombre:'David S\u00e1nchez',cargo:'Entrenador Sub16',desc:'T\u00e9cnico certificado por la Federaci\u00f3n Espa\u00f1ola de B\u00e9isbol y S\u00f3ftbol.'},{nombre:'Marc Torres',cargo:'Entrenador Sub14',desc:'Apasionado del b\u00e9isbol desde joven, lleva 10 a\u00f1os formando a los cadetes del club.'},{nombre:'Laura P\u00e9rez',cargo:'Entrenadora Sub12',desc:'Primera entrenadora de la historia del club, referente del b\u00e9isbol femenino catal\u00e1n.'},{nombre:'Carlos Mart\u00ednez',cargo:'Entrenador Sub10',desc:'Especialista en iniciaci\u00f3n deportiva y desarrollo motor en edades tempranas.'}]; %>
            <% tecnicos.forEach(function(t) { %>
                <div class="card card-hover" style="padding:1.5rem;text-align:center">
                  <div
                    style="width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--accent-dark),var(--accent));color:#fff;font-size:1.5rem;font-weight:900;font-family:var(--font-head);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
                    <%= t.nombre.charAt(0) %>
                  </div>
                  <h3 style="font-size:1rem;margin-bottom:.25rem">
                    <%= t.nombre %>
                  </h3>
                  <p
                    style="font-size:.78rem;color:var(--accent);font-weight:700;margin-bottom:.75rem;text-transform:uppercase;letter-spacing:.04em">
                    <%= t.cargo %>
                  </p>
                  <p style="font-size:.82rem;color:var(--text2)">
                    <%= t.desc %>
                  </p>
                </div>
                <% }) %>
          </div>
        </div>
      </section>

      <!-- ══════════ GALERÍA ══════════ -->
      <section class="section-py">
        <div class="container">
          <div class="section-header">
            <div>
              <div class="section-label">Archivo histórico</div>
              <h2 class="section-title">Galería</h2>
            </div>
          </div>
          <div class="gallery-grid">
            <div class="gallery-item">
              <img src="/images/bar.webp" alt="Bar CB Granollers">
            </div>
            <div class="gallery-item">
              <img src="/images/pitcher.webp" alt="Pitcher CB Granollers">
            </div>
            <div class="gallery-item">
              <img src="/images/bullpen.webp" alt="Bullpen CB Granollers">
            </div>
            <div class="gallery-item">
              <img src="/images/banch.webp" alt="Banquillo CB Granollers">
            </div>
            <div class="gallery-item">
              <img src="/images/sub18.webp" alt="Equipo SUB18 CB Granollers">
            </div>
            <div class="gallery-item">
              <img src="/images/sub14anotando.webp" alt="Equipo SUB14 CB Granollers">
            </div>
            <div class="gallery-item">
              <img src="/images/family.webp" alt="Familia CB Granollers">
            </div>
            <div class="gallery-item">
              <img src="/images/formacion.webp" alt="Formación CB Granollers">
            </div>
          </div>
        </div>
      </section>

      <!-- ══════════ CTA ══════════ -->
      <section class="cta-banner">
        <div class="container">
          <h2>Forma parte de la leyenda</h2>
          <p>Únete a una comunidad de apasionados del béisbol y escribe tu historia con nosotros.</p>
          <div class="cta-actions">
            <a href="/auth/registro" class="btn btn-white btn-lg">Registrarse</a>
            <a href="/contacto" class="btn btn-lg" style="background:rgba(255,255,255,0.15);color:#fff;border:2px solid rgba(255,255,255,0.7);backdrop-filter:blur(4px)">Más información</a>
          </div>
        </div>
      </section>

      <%- include('partials/footer') %>

<script>
/* ── Contador animado club-stats ─────────────────────────────────────────── */
(function () {
  var stats = [
    { selector: '.club-stat-item:nth-child(1) .club-stat-num', end: 110,  prefix: '+', start: 0,    duration: 1600 },
    { selector: '.club-stat-item:nth-child(2) .club-stat-num', end: 20,   prefix: '+', start: 0,    duration: 1200 },
    { selector: '.club-stat-item:nth-child(3) .club-stat-num', end: 1985, prefix: '',  start: 1960, duration: 1800 },
    { selector: '.club-stat-item:nth-child(4) .club-stat-num', end: 8,    prefix: '',  start: 0,    duration: 900  },
  ];

  function easeOutQuad(t) { return 1 - (1 - t) * (1 - t); }

  function animateStat(cfg) {
    var el = document.querySelector(cfg.selector);
    if (!el) return;
    var startTime = null;
    var range = cfg.end - cfg.start;
    function step(ts) {
      if (!startTime) startTime = ts;
      var progress = Math.min((ts - startTime) / cfg.duration, 1);
      el.textContent = cfg.prefix + Math.round(cfg.start + range * easeOutQuad(progress));
      if (progress < 1) requestAnimationFrame(step);
      else el.textContent = cfg.prefix + cfg.end;
    }
    requestAnimationFrame(step);
  }

  var container = document.querySelector('.club-stats');
  if (!container) return;
  var fired = false;
  new IntersectionObserver(function (entries) {
    if (entries[0].isIntersecting && !fired) {
      fired = true;
      stats.forEach(function (cfg, i) {
        setTimeout(function () { animateStat(cfg); }, i * 120);
      });
    }
  }, { threshold: 0.4 }).observe(container);
})();
</script>