<%- include('../partials/head', { title: 'Inscripciones · Admin' }) %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<main>
  <div class="container">
    <div class="admin-layout">
      <aside class="admin-sidebar">
        <div class="card" style="padding:.75rem">
          <p class="admin-sidebar-title">Panel Admin</p>
          <a href="/admin/dashboard"     class="admin-nav-item">📊 Dashboard</a>
          <a href="/admin/usuarios"      class="admin-nav-item">👥 Usuarios</a>
          <a href="/admin/inscripciones" class="admin-nav-item active">📋 Inscripciones</a>
          <a href="/admin/productos"     class="admin-nav-item">🛍️ Productos</a>
          <a href="/admin/noticias"      class="admin-nav-item">📰 Noticias</a>
          <a href="/admin/partidos"      class="admin-nav-item">⚾ Partidos</a>
          <div style="height:1px;background:var(--border);margin:.5rem 0"></div>
          <a href="/" class="admin-nav-item">🏠 Ver web</a>
        </div>
      </aside>

      <div class="admin-content" style="padding:2rem 0">
        <div class="section-header" style="margin-bottom:1rem">
          <h1 class="admin-page-title" style="margin-bottom:0">Inscripciones</h1>
          <button class="btn btn-primary btn-sm" onclick="document.getElementById('formNuevo').style.display = document.getElementById('formNuevo').style.display === 'none' ? 'block' : 'none'">+ Nuevo jugador/técnico</button>
        </div>

        <!-- Formulario para crear jugador o técnico -->
        <div id="formNuevo" class="card" style="padding:1.5rem;margin-bottom:1.5rem;display:none">
          <h3 style="font-size:1rem;margin-bottom:1rem">Crear jugador o técnico</h3>
          <form action="/admin/jugadores" method="POST">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem">
              <div>
                <label class="form-label">Nombre *</label>
                <input type="text" name="nombre" class="form-control" required>
              </div>
              <div>
                <label class="form-label">Apellidos *</label>
                <input type="text" name="apellidos" class="form-control" required>
              </div>
              <div>
                <label class="form-label">Email *</label>
                <input type="email" name="email" class="form-control" required>
              </div>
              <div>
                <label class="form-label">Contraseña *</label>
                <input type="password" name="password" class="form-control" placeholder="Mínimo 8 caracteres" required minlength="8">
              </div>
              <div>
                <label class="form-label">Teléfono</label>
                <input type="text" name="telefono" class="form-control">
              </div>
              <div>
                <label class="form-label">Fecha nacimiento</label>
                <input type="date" name="fechaNacimiento" class="form-control">
              </div>
              <div>
                <label class="form-label">Rol *</label>
                <select name="rol" class="form-control" required>
                  <option value="JUGADOR">Jugador</option>
                  <option value="TECNICO">Técnico</option>
                </select>
              </div>
              <div>
                <label class="form-label">Categoría *</label>
                <select name="categoriaId" class="form-control" required>
                  <% if (typeof categorias !== 'undefined') { %>
                    <% categorias.forEach(function(c) { %>
                      <option value="<%= c.id %>"><%= c.nombre %></option>
                    <% }) %>
                  <% } %>
                </select>
              </div>
              <div>
                <label class="form-label">Temporada</label>
                <input type="text" name="temporada" class="form-control" value="2025-2026">
              </div>
            </div>
            <div style="margin-top:1rem;display:flex;gap:.5rem">
              <button type="submit" class="btn btn-primary btn-sm">Crear</button>
              <button type="button" class="btn btn-outline btn-sm" onclick="document.getElementById('formNuevo').style.display='none'">Cancelar</button>
            </div>
          </form>
        </div>

        <div style="display:flex;gap:.5rem;margin-bottom:1.5rem;flex-wrap:wrap">
          <button class="btn btn-primary btn-sm" onclick="filtrarIns('TODAS')">Todas</button>
          <button class="btn btn-outline btn-sm" onclick="filtrarIns('PENDIENTE')">Pendientes</button>
          <button class="btn btn-outline btn-sm" onclick="filtrarIns('APROBADA')">Aprobadas</button>
          <button class="btn btn-outline btn-sm" onclick="filtrarIns('RECHAZADA')">Rechazadas</button>
        </div>
        <div class="table-wrap">
          <table class="table" id="insTable">
            <thead>
              <tr>
                <th>Persona</th>
                <th>Email</th>
                <th>Rol actual / Solicitado</th>
                <th>Categoría</th>
                <th>Temporada</th>
                <th>Estado</th>
                <th>Tutor legal</th>
                <th>Cambiar estado</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% if (typeof inscripciones !== 'undefined' && inscripciones && inscripciones.length > 0) { %>
                <% inscripciones.forEach(function(ins) { %>
                  <tr data-estado="<%= ins.estado %>">
                    <td>
                      <strong><%= ins.persona ? ins.persona.nombre + ' ' + ins.persona.apellidos : '–' %></strong>
                      <% if (ins.persona && ins.persona.fechaNacimiento) {
                           const hoy = new Date();
                           const nac = new Date(ins.persona.fechaNacimiento);
                           let edad = hoy.getFullYear() - nac.getFullYear();
                           if (hoy.getMonth() < nac.getMonth() || (hoy.getMonth() === nac.getMonth() && hoy.getDate() < nac.getDate())) edad--;
                      %>
                        <br><small style="color:var(--text2)"><%= edad %> años</small>
                      <% } %>
                    </td>
                    <td style="color:var(--text2);font-size:.85rem"><%= ins.persona ? ins.persona.email : '–' %></td>
                    <td>
                      <% const rolActual = ins.persona && ins.persona.rol ? ins.persona.rol.tipo : 'SOCIO'; %>
                      <span class="badge <%= rolActual === 'TECNICO' ? 'badge-primary' : rolActual === 'JUGADOR' ? 'badge-success' : 'badge-neutral' %> badge-sm"><%= rolActual %></span>
                      <br><small style="color:var(--text2)">→ <strong><%= ins.rolSolicitado || 'JUGADOR' %></strong></small>
                    </td>
                    <td><span class="badge badge-primary badge-sm"><%= ins.categoria ? ins.categoria.nombre : '–' %></span></td>
                    <td style="color:var(--text2)"><%= ins.temporada || '–' %></td>
                    <td><span class="badge <%= ins.estado === 'APROBADA' ? 'badge-success' : ins.estado === 'RECHAZADA' ? 'badge-danger' : 'badge-warning' %> badge-sm"><%= ins.estado %></span></td>
                    <td style="font-size:.8rem">
                      <% if (ins.tutorLegal) { %>
                        <strong><%= ins.tutorLegal.nombre %> <%= ins.tutorLegal.apellidos %></strong><br>
                        <span style="color:var(--text2)">DNI: <%= ins.tutorLegal.dni %></span>
                      <% } else { %>
                        <span style="color:var(--text3)">–</span>
                      <% } %>
                    </td>
                    <td>
                      <form action="/admin/inscripciones/<%= ins.id %>" method="POST" class="inline-form">
                        <select name="estado" class="form-control" style="padding:.3rem .6rem;font-size:.82rem;width:auto" onchange="this.form.submit()">
                          <% ['PENDIENTE','APROBADA','RECHAZADA'].forEach(function(e) { %><option value="<%= e %>" <%= ins.estado === e ? 'selected' : '' %>><%= e %></option><% }) %>
                        </select>
                      </form>
                    </td>
                    <td>
                      <form action="/admin/inscripciones/<%= ins.id %>/eliminar" method="POST" class="inline-form" onsubmit="return confirm('¿Eliminar la inscripción de <%= ins.persona ? ins.persona.nombre : '' %>?')">
                        <button type="submit" class="btn btn-sm" style="background:#ef4444;color:#fff;padding:.25rem .6rem;font-size:.78rem">Eliminar</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="9" style="text-align:center;color:var(--text3);padding:3rem">Sin inscripciones</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
function filtrarIns(estado) {
  document.querySelectorAll('#insTable tbody tr[data-estado]').forEach(r => {
    r.style.display = (estado === 'TODAS' || r.dataset.estado === estado) ? '' : 'none';
  });
}
</script>

<%- include('../partials/footer') %>
