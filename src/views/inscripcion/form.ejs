<%- include('../partials/head', { title: 'Inscripción' }) %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="page-header">
  <div class="container">
    <div class="breadcrumb">
      <a href="/">Inicio</a><span class="breadcrumb-sep">›</span><span>Inscripción</span>
    </div>
    <h1 class="page-header-title">Formulario de inscripción</h1>
    <p class="page-header-desc">Selecciona la categoría y el rol en los que deseas inscribirte para la temporada 2025-2026.</p>
  </div>
</div>

<main>
  <div class="container section-py">
    <div style="max-width:700px;margin:0 auto">

      <form action="/inscripcion" method="POST" id="formInscripcion">

        <!-- Categoría -->
        <div class="card" style="padding:2rem;margin-bottom:1.5rem">
          <h3 style="margin-bottom:1.5rem">Selecciona tu categoría</h3>
          <% const catColors={SUB10:'cat-sub10',SUB12:'cat-sub12',SUB14:'cat-sub14',SUB16:'cat-sub16',SUB18:'cat-sub18',SENIOR:'cat-senior'}; %>
          <% const catEmoji={SUB10:'🧢',SUB12:'⚾',SUB14:'🥊',SUB16:'💪',SUB18:'🔥',SENIOR:'🏆'}; %>
          <% const catEdad={SUB10:'Hasta 10 años',SUB12:'11-12 años',SUB14:'13-14 años',SUB16:'15-16 años',SUB18:'17-18 años',SENIOR:'+18 años'}; %>
          <div class="inscripcion-grid">
            <% if (typeof categorias !== 'undefined' && categorias) { %>
              <% categorias.forEach(function(cat) { %>
                <div class="inscripcion-option">
                  <input type="radio" name="categoriaId" id="cat-<%= cat.id %>" value="<%= cat.id %>" required>
                  <label class="inscripcion-label" for="cat-<%= cat.id %>">
                    <div class="cat-badge <%= catColors[cat.nombre] || '' %>"><%= catEmoji[cat.nombre] || '⚾' %></div>
                    <strong><%= cat.nombre %></strong>
                    <small><%= catEdad[cat.nombre] || '' %></small>
                  </label>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

        <!-- Rol solicitado -->
        <div class="card" style="padding:2rem;margin-bottom:1.5rem">
          <h3 style="margin-bottom:1.25rem">¿Cómo quieres participar?</h3>
          <div style="display:flex;gap:1rem;flex-wrap:wrap">
            <label style="flex:1;min-width:180px;cursor:pointer">
              <input type="radio" name="rolSolicitado" value="JUGADOR" checked style="margin-right:.5rem">
              <strong>Jugador/a</strong>
              <p style="font-size:.82rem;color:var(--text2);margin:.25rem 0 0 1.3rem">Quiero unirme como deportista activo/a.</p>
            </label>
            <label style="flex:1;min-width:180px;cursor:pointer">
              <input type="radio" name="rolSolicitado" value="TECNICO" style="margin-right:.5rem">
              <strong>Técnico/a</strong>
              <p style="font-size:.82rem;color:var(--text2);margin:.25rem 0 0 1.3rem">Quiero participar como entrenador/a o cuerpo técnico.</p>
            </label>
          </div>
        </div>

        <!-- Temporada y notas -->
        <div class="card" style="padding:2rem;margin-bottom:1.5rem">
          <h3 style="margin-bottom:1.25rem">Temporada</h3>
          <div class="form-group">
            <label class="form-label">Temporada</label>
            <select name="temporada" class="form-control" required>
              <option value="2025-2026" selected>2025-2026</option>
              <option value="2026-2027">2026-2027</option>
            </select>
          </div>
          <div class="form-group" style="margin-bottom:0">
            <label class="form-label">Notas adicionales (opcional)</label>
            <textarea name="notas" class="form-control" rows="3" placeholder="Lesiones, experiencia previa, preferencias…" style="resize:vertical"></textarea>
          </div>
        </div>

        <!-- Datos del tutor legal (menores o sin fecha de nacimiento) -->
        <% if (typeof mostrarTutor !== 'undefined' && mostrarTutor) { %>
        <div class="card" id="seccionTutor" style="padding:2rem;margin-bottom:1.5rem;border-color:var(--accent)">
          <h3 style="margin-bottom:.5rem;color:var(--accent)">
            👪 Datos del padre/madre o tutor legal
          </h3>
          <% if (typeof esMenor !== 'undefined' && esMenor) { %>
            <p style="font-size:.85rem;color:var(--text2);margin-bottom:1.25rem">
              Como menor de edad, es <strong>obligatorio</strong> facilitar los datos de un progenitor o tutor legal para tramitar la inscripción.
            </p>
          <% } else { %>
            <p style="font-size:.85rem;color:var(--text2);margin-bottom:1.25rem">
              No tenemos tu fecha de nacimiento registrada. Si eres menor de 18 años, estos datos son <strong>obligatorios</strong>.
            </p>
          <% } %>
          <div style="display:grid;gap:1rem;grid-template-columns:1fr 1fr">
            <div class="form-group" style="margin-bottom:0">
              <label class="form-label">Nombre del tutor <span style="color:red">*</span></label>
              <input type="text" name="tutorNombre" class="form-control" placeholder="Nombre" <%= typeof esMenor !== 'undefined' && esMenor ? 'required' : '' %>>
            </div>
            <div class="form-group" style="margin-bottom:0">
              <label class="form-label">Apellidos del tutor <span style="color:red">*</span></label>
              <input type="text" name="tutorApellidos" class="form-control" placeholder="Apellidos" <%= typeof esMenor !== 'undefined' && esMenor ? 'required' : '' %>>
            </div>
          </div>
          <div class="form-group" style="margin-top:1rem;margin-bottom:0">
            <label class="form-label">DNI del tutor <span style="color:red">*</span></label>
            <input type="text" name="tutorDni" class="form-control" placeholder="12345678A" pattern="[0-9]{8}[A-Za-z]" title="Formato: 8 dígitos seguidos de una letra" <%= typeof esMenor !== 'undefined' && esMenor ? 'required' : '' %>>
          </div>
        </div>
        <% } %>

        <!-- Info documentación -->
        <div class="card" style="padding:1.5rem;margin-bottom:1.5rem;background:rgba(var(--accent-rgb),.06);border-color:rgba(var(--accent-rgb),.2)">
          <h4 style="margin-bottom:.75rem;font-size:.95rem">📋 Documentación requerida</h4>
          <p style="font-size:.85rem;color:var(--text2);line-height:1.7">
            Tras enviar esta solicitud, deberás aportar en el club: DNI o pasaporte, certificado médico deportivo
            y justificante del pago de la cuota anual. La inscripción quedará pendiente de aprobación.
          </p>
        </div>

        <button type="submit" class="btn btn-primary btn-full btn-lg">
          Enviar solicitud de inscripción
        </button>
      </form>

    </div>
  </div>
</main>

<%- include('../partials/footer') %>
