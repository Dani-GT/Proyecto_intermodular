<%- include('../partials/head', { title: 'Mis Inscripciones' }) %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="page-header">
  <div class="container">
    <div class="breadcrumb">
      <a href="/">Inicio</a><span class="breadcrumb-sep">›</span>
      <a href="/auth/perfil">Mi perfil</a><span class="breadcrumb-sep">›</span>
      <span>Mis inscripciones</span>
    </div>
    <h1 class="page-header-title">Mis inscripciones</h1>
    <p class="page-header-desc">Historial de tus solicitudes de inscripción a categorías del club.</p>
  </div>
</div>

<main>
  <div class="container section-py">
    <div style="max-width:800px;margin:0 auto">

      <% if (inscripciones && inscripciones.length > 0) { %>
        <div style="display:flex;flex-direction:column;gap:1rem">
          <% inscripciones.forEach(function(ins) { %>
            <div class="card" style="padding:1.5rem;display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap">
              <div style="width:56px;height:56px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:1.5rem;flex-shrink:0">⚾</div>
              <div style="flex:1;min-width:0">
                <div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;margin-bottom:.25rem">
                  <strong style="font-size:1.1rem"><%= ins.categoria.nombre %></strong>
                  <span class="badge <%=
                    ins.estado === 'APROBADA' ? 'badge-success' :
                    ins.estado === 'PENDIENTE' ? 'badge-warning' :
                    ins.estado === 'RECHAZADA' ? 'badge-danger' : 'badge-secondary'
                  %>"><%= ins.estado %></span>
                </div>
                <p style="font-size:.88rem;color:var(--text2);margin:0">
                  Temporada <strong><%= ins.temporada %></strong>
                  · Solicitada el <%= new Date(ins.createdAt).toLocaleDateString('es', {day:'2-digit',month:'long',year:'numeric'}) %>
                </p>
                <% if (ins.notas) { %>
                  <p style="font-size:.82rem;color:var(--text3);margin-top:.25rem;font-style:italic">"<%= ins.notas %>"</p>
                <% } %>
              </div>
              <% if (ins.estado === 'PENDIENTE') { %>
                <span style="font-size:.8rem;color:var(--text3)">⏳ En revisión</span>
              <% } %>
            </div>
          <% }) %>
        </div>

        <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap">
          <a href="/inscripcion" class="btn btn-primary">+ Nueva inscripción</a>
          <a href="/auth/perfil" class="btn btn-outline">← Volver al perfil</a>
        </div>

      <% } else { %>
        <div class="card" style="padding:4rem;text-align:center">
          <div style="font-size:3rem;margin-bottom:1rem">📋</div>
          <h3 style="margin-bottom:.5rem">Sin inscripciones</h3>
          <p style="color:var(--text2);margin-bottom:1.5rem">Todavía no te has inscrito en ninguna categoría.</p>
          <a href="/inscripcion" class="btn btn-primary">Inscribirme ahora</a>
        </div>
      <% } %>

    </div>
  </div>
</main>

<%- include('../partials/footer') %>
