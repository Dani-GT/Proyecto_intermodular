<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <%
    var _title  = (typeof title !== 'undefined' && title) ? title : 'Club Béisbol Granollers';
    var _desc   = (typeof description !== 'undefined' && description)
                    ? description
                    : 'Club Béisbol Granollers — Pasión por el béisbol en Granollers desde 1985. Inscripciones abiertas para la temporada 2026-2027.';
    var _image  = (typeof ogImage !== 'undefined' && ogImage) ? ogImage : 'https://cb-granollers.onrender.com/images/og-default.jpg';
    var _canon  = (typeof canonical !== 'undefined' && canonical) ? canonical : 'https://cb-granollers.onrender.com';
    var _ftitle = (_title.indexOf('CB Granollers') === -1 && _title.indexOf('Club Béisbol') === -1)
                    ? _title + ' · CB Granollers'
                    : _title;
  %>

  <!-- SEO básico -->
  <title><%= _ftitle %></title>
  <meta name="description" content="<%= _desc %>">
  <meta name="robots"      content="index, follow">
  <meta name="author"      content="Club Béisbol Granollers">
  <link rel="canonical"    href="<%= _canon %>">

  <!-- Open Graph -->
  <meta property="og:type"        content="website">
  <meta property="og:site_name"   content="Club Béisbol Granollers">
  <meta property="og:title"       content="<%= _ftitle %>">
  <meta property="og:description" content="<%= _desc %>">
  <meta property="og:image"       content="<%= _image %>">
  <meta property="og:url"         content="<%= _canon %>">
  <meta property="og:locale"      content="es_ES">

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:title"       content="<%= _ftitle %>">
  <meta name="twitter:description" content="<%= _desc %>">
  <meta name="twitter:image"       content="<%= _image %>">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
  <link rel="alternate icon"            href="/images/favicon.ico">

  <!-- Tema: cargado antes de renderizar para evitar flash -->
  <script>
    (function(){
      var t = localStorage.getItem('cbg-theme');
      if(t) document.documentElement.setAttribute('data-theme', t);
    })();
  </script>

  <!-- Critical inline CSS: evita FOUC mientras carga el stylesheet principal -->
  <style>
    :root { --bg: #f8fafc; --text: #0f172a; }
    [data-theme="dark"] { --bg: #0f172a; --text: #f1f5f9; }
    html { scroll-behavior: smooth; }
    body { margin: 0; background: var(--bg); color: var(--text); font-family: system-ui, sans-serif; }
    .navbar { position: sticky; top: 0; z-index: 100; background: var(--bg); }
  </style>

  <!-- Google Fonts — no bloqueante -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="dns-prefetch" href="https://fonts.googleapis.com">
  <link rel="preload" as="style"
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800;900&family=Inter:wght@400;500;600&display=swap"
        onload="this.onload=null;this.rel='stylesheet'">
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800;900&family=Inter:wght@400;500;600&display=swap">
  </noscript>

  <!-- CSS principal — no bloqueante -->
  <link rel="preload" as="style" href="/css/style.css"
        onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/css/style.css"></noscript>
</head>
<body>
