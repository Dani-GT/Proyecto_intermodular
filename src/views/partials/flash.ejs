<% if (mensajeExito && mensajeExito.length > 0) { %>
  <div style="position:sticky;top:var(--nav-h);z-index:100;padding:.75rem 1.5rem;background:rgba(34,197,94,.12);border-bottom:1px solid rgba(34,197,94,.25)">
    <div class="container" style="display:flex;align-items:center;gap:.75rem">
      <span>✅</span>
      <span style="color:#4ade80;font-size:.9rem"><%= mensajeExito[0] %></span>
      <button class="alert-close" onclick="this.closest('[style]').remove()" style="margin-left:auto">×</button>
    </div>
  </div>
<% } %>
<% if (mensajeError && mensajeError.length > 0) { %>
  <div style="position:sticky;top:var(--nav-h);z-index:100;padding:.75rem 1.5rem;background:rgba(239,68,68,.12);border-bottom:1px solid rgba(239,68,68,.25)">
    <div class="container" style="display:flex;align-items:center;gap:.75rem">
      <span>❌</span>
      <span style="color:#f87171;font-size:.9rem"><%= mensajeError[0] %></span>
      <button class="alert-close" onclick="this.closest('[style]').remove()" style="margin-left:auto">×</button>
    </div>
  </div>
<% } %>
