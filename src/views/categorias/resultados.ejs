<%- include('../partials/head', { title: 'Resultados' }) %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="page-header">
  <div class="container">
    <div class="breadcrumb">
      <a href="/">Inicio</a><span class="breadcrumb-sep">›</span>
      <a href="/categorias">Categorías</a><span class="breadcrumb-sep">›</span>
      <span>Resultados</span>
    </div>
    <h1 class="page-header-title">Resultados<%= (typeof categoriaFiltro !== 'undefined' && categoriaFiltro) ? ' — ' + categoriaFiltro.nombre : '' %></h1>
    <p class="page-header-desc">Consulta los últimos resultados <%= (typeof categoriaFiltro !== 'undefined' && categoriaFiltro) ? 'del equipo ' + categoriaFiltro.nombre : 'de todos los equipos del club' %>.</p>
  </div>
</div>

<main>
  <div class="container section-py">
    <!-- Tabs por categoría -->
    <% const filtroActivo = (typeof categoriaFiltro !== 'undefined' && categoriaFiltro) ? categoriaFiltro.nombre : 'TODAS'; %>
    <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:2rem">
      <a href="/categorias/resultados" class="btn <%= filtroActivo === 'TODAS' ? 'btn-primary' : 'btn-outline' %> btn-sm">Todas</a>
      <% const catNames = ['SUB10','SUB12','SUB14','SUB16','SUB18','SENIOR']; %>
      <% catNames.forEach(function(c) { %>
        <a href="/categorias/<%= c.toLowerCase() %>/resultados" class="btn <%= filtroActivo === c ? 'btn-primary' : 'btn-outline' %> btn-sm"><%= c %></a>
      <% }) %>
    </div>

    <div class="results-grid" id="resultadosGrid">
      <% if (typeof partidos !== 'undefined' && partidos && partidos.length > 0) { %>
        <% partidos.forEach(function(p) { %>
          <% const partes = p.resultado ? p.resultado.split('-') : []; %>
          <% const pLocal = partes[0] ? parseInt(partes[0]) : 0; %>
          <% const pVisit = partes[1] ? parseInt(partes[1]) : 0; %>
          <% const ganoCBG = (p.esLocal && pLocal > pVisit) || (!p.esLocal && pVisit > pLocal); %>
          <% const fecha = new Date(p.fecha); %>
          <div class="card result-card" data-cat="<%= p.categoria ? p.categoria.nombre : '' %>">
            <div class="result-date">
              <div class="result-date-day"><%= fecha.getDate() %></div>
              <div class="result-date-mon"><%= fecha.toLocaleString('es',{month:'short'}).toUpperCase() %></div>
            </div>
            <div class="result-teams">
              <div class="result-team <%= ganoCBG ? 'winner' : '' %>">
                <span class="result-team-name">CB Granollers <%= p.esLocal ? '(L)' : '(V)' %></span>
                <span class="result-team-score"><%= p.esLocal ? pLocal : pVisit %></span>
              </div>
              <div class="result-divider"></div>
              <div class="result-team <%= !ganoCBG ? 'winner' : '' %>">
                <span class="result-team-name"><%= p.rival %></span>
                <span class="result-team-score"><%= p.esLocal ? pVisit : pLocal %></span>
              </div>
            </div>
            <div class="result-location">
              <span class="badge <%= ganoCBG ? 'badge-success' : 'badge-danger' %> badge-sm"><%= ganoCBG ? '✓ Victoria' : '✗ Derrota' %></span><br>
              <span style="font-size:.75rem;color:var(--text3);margin-top:.4rem;display:block"><%= p.categoria ? p.categoria.nombre : '' %></span>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="card" style="padding:4rem;text-align:center;grid-column:1/-1">
          <div style="font-size:3rem;margin-bottom:1rem">📊</div>
          <h3>Sin resultados disponibles</h3>
          <p style="color:var(--text2)">Los resultados aparecerán aquí una vez se disputen los partidos.</p>
        </div>
      <% } %>
    </div>
  </div>
</main>

<script>
function filtrarCat(cat) {
  document.querySelectorAll('[id^="btn-"]').forEach(b => {
    b.className = b.id === 'btn-' + cat ? 'btn btn-primary btn-sm' : 'btn btn-outline btn-sm';
  });
  document.querySelectorAll('#resultadosGrid .card').forEach(card => {
    card.style.display = (cat === 'TODAS' || card.dataset.cat === cat) ? '' : 'none';
  });
}
</script>

<%- include('../partials/footer') %>
