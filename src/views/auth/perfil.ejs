<%- include('../partials/head', { title: 'Mi perfil' }) %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="page-header">
  <div class="container">
    <h1 class="page-header-title">Mi perfil</h1>
  </div>
</div>

<main>
  <div class="container section-py">

    <!-- Cabecera -->
    <div class="profile-header">
      <div class="profile-avatar-big"><%= persona.nombre.charAt(0).toUpperCase() %></div>
      <div>
        <h2 class="profile-name"><%= persona.nombre %> <%= persona.apellidos %></h2>
        <p class="profile-email"><%= persona.email %></p>
        <div style="margin-top:.5rem;display:flex;gap:.5rem;flex-wrap:wrap">
          <span class="badge badge-primary"><%= persona.rol ? persona.rol.tipo : 'SOCIO' %></span>
          <% if (persona.telefono) { %><span class="badge badge-neutral">📞 <%= persona.telefono %></span><% } %>
          <% if (persona.fechaNacimiento) { %><span class="badge badge-neutral">🎂 <%= new Date(persona.fechaNacimiento).toLocaleDateString('es') %></span><% } %>
        </div>
      </div>
    </div>

    <% if (persona.rol && persona.rol.tipo === 'ADMIN') { %>

    <!-- ══ VISTA ADMIN ══ -->
    <div class="profile-tabs">
      <button class="profile-tab active" data-tab="admin-panel">🖥️ Panel de administración</button>
      <button class="profile-tab" data-tab="editar">✏️ Mis datos</button>
    </div>

    <div id="tab-admin-panel" class="profile-panel">

      <div class="card" style="padding:1.5rem;margin-bottom:1.5rem;background:rgba(var(--accent-rgb),.06);border-color:rgba(var(--accent-rgb),.25)">
        <p style="margin:0;font-size:.9rem;color:var(--text2)">
          Accede al panel completo para gestionar todos los apartados del club.
        </p>
      </div>

      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem">

        <a href="/admin/dashboard" class="card card-hover" style="padding:1.75rem;text-decoration:none;text-align:center">
          <div style="font-size:2rem;margin-bottom:.6rem">📊</div>
          <div style="font-weight:700;color:var(--text)">Dashboard</div>
          <div style="font-size:.8rem;color:var(--text2);margin-top:.25rem">Resumen general</div>
        </a>

        <a href="/admin/inscripciones" class="card card-hover" style="padding:1.75rem;text-decoration:none;text-align:center">
          <div style="font-size:2rem;margin-bottom:.6rem">📋</div>
          <div style="font-weight:700;color:var(--text)">Inscripciones</div>
          <div style="font-size:.8rem;color:var(--text2);margin-top:.25rem">Gestionar solicitudes</div>
        </a>

        <a href="/admin/usuarios" class="card card-hover" style="padding:1.75rem;text-decoration:none;text-align:center">
          <div style="font-size:2rem;margin-bottom:.6rem">👥</div>
          <div style="font-weight:700;color:var(--text)">Usuarios</div>
          <div style="font-size:.8rem;color:var(--text2);margin-top:.25rem">Ver y editar socios</div>
        </a>

        <a href="/admin/productos" class="card card-hover" style="padding:1.75rem;text-decoration:none;text-align:center">
          <div style="font-size:2rem;margin-bottom:.6rem">🛍️</div>
          <div style="font-weight:700;color:var(--text)">Productos</div>
          <div style="font-size:.8rem;color:var(--text2);margin-top:.25rem">Tienda y stock</div>
        </a>

        <a href="/admin/noticias" class="card card-hover" style="padding:1.75rem;text-decoration:none;text-align:center">
          <div style="font-size:2rem;margin-bottom:.6rem">📰</div>
          <div style="font-weight:700;color:var(--text)">Noticias</div>
          <div style="font-size:.8rem;color:var(--text2);margin-top:.25rem">Publicar y editar</div>
        </a>

        <a href="/admin/partidos" class="card card-hover" style="padding:1.75rem;text-decoration:none;text-align:center">
          <div style="font-size:2rem;margin-bottom:.6rem">⚾</div>
          <div style="font-weight:700;color:var(--text)">Partidos</div>
          <div style="font-size:.8rem;color:var(--text2);margin-top:.25rem">Calendario y resultados</div>
        </a>

      </div>
    </div>

    <% } else { %>

    <!-- ══ VISTA SOCIO / JUGADOR ══ -->
    <div class="profile-tabs">
      <button class="profile-tab active" data-tab="inscripciones">📋 Mis inscripciones</button>
      <button class="profile-tab" data-tab="compras">🛍️ Mis compras</button>
      <button class="profile-tab" data-tab="editar">✏️ Editar datos</button>
    </div>

    <!-- Panel inscripciones -->
    <div id="tab-inscripciones" class="profile-panel">
      <% if (typeof inscripciones !== 'undefined' && inscripciones && inscripciones.length > 0) { %>
        <div class="table-wrap">
          <table class="table">
            <thead>
              <tr>
                <th>Categoría</th>
                <th>Rol solicitado</th>
                <th>Temporada</th>
                <th>Estado</th>
                <th>Fecha solicitud</th>
                <th>Notas</th>
              </tr>
            </thead>
            <tbody>
              <% inscripciones.forEach(function(ins) { %>
                <tr>
                  <td><strong><%= ins.categoria ? ins.categoria.nombre : '–' %></strong></td>
                  <td><%= ins.rolSolicitado || 'JUGADOR' %></td>
                  <td><%= ins.temporada || '2025-2026' %></td>
                  <td>
                    <span class="badge <%= ins.estado === 'APROBADA' ? 'badge-success' : ins.estado === 'RECHAZADA' ? 'badge-danger' : 'badge-warning' %>">
                      <%= ins.estado %>
                    </span>
                  </td>
                  <td style="color:var(--text2);font-size:.85rem"><%= new Date(ins.createdAt).toLocaleDateString('es') %></td>
                  <td style="color:var(--text2);font-size:.85rem"><%= ins.notas || '–' %></td>
                </tr>
                <% if (ins.tutorLegal) { %>
                <tr style="background:rgba(var(--accent-rgb),.04)">
                  <td colspan="6" style="font-size:.82rem;color:var(--text2);padding:.5rem 1rem">
                    👪 <strong>Tutor legal:</strong> <%= ins.tutorLegal.nombre %> <%= ins.tutorLegal.apellidos %> — DNI: <%= ins.tutorLegal.dni %>
                  </td>
                </tr>
                <% } %>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="card" style="padding:3rem;text-align:center">
          <div style="font-size:2.5rem;margin-bottom:.75rem">📋</div>
          <h3 style="margin-bottom:.5rem">Sin inscripciones</h3>
          <p style="color:var(--text2);margin-bottom:1.5rem">Todavía no te has inscrito en ninguna categoría.</p>
          <a href="/inscripcion" class="btn btn-primary">Inscribirme ahora</a>
        </div>
      <% } %>
    </div>

    <!-- Panel compras -->
    <div id="tab-compras" class="profile-panel hidden">
      <% if (typeof compras !== 'undefined' && compras && compras.length > 0) { %>
        <div class="table-wrap">
          <table class="table">
            <thead>
              <tr>
                <th>Pedido</th>
                <th>Productos</th>
                <th>Total</th>
                <th>Estado</th>
                <th>Fecha</th>
              </tr>
            </thead>
            <tbody>
              <% compras.forEach(function(c) { %>
                <tr>
                  <td><code style="font-size:.8rem;color:var(--text3)">#<%= c.id.substring(0,8) %></code></td>
                  <td style="color:var(--text2);font-size:.85rem">
                    <% if (c.CompraProducto) { %>
                      <%= c.CompraProducto.map(cp => cp.producto ? cp.producto.nombre : '?').join(', ').substring(0,50) + (c.CompraProducto.length > 1 ? '…' : '') %>
                    <% } %>
                  </td>
                  <td><strong><%= c.total ? Number(c.total).toFixed(2) + ' €' : '–' %></strong></td>
                  <td>
                    <span class="badge <%= c.estado === 'COMPLETADA' ? 'badge-success' : c.estado === 'CANCELADA' ? 'badge-danger' : 'badge-warning' %>">
                      <%= c.estado %>
                    </span>
                  </td>
                  <td style="color:var(--text2);font-size:.85rem"><%= new Date(c.createdAt).toLocaleDateString('es') %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="card" style="padding:3rem;text-align:center">
          <div style="font-size:2.5rem;margin-bottom:.75rem">🛍️</div>
          <h3 style="margin-bottom:.5rem">Sin compras</h3>
          <p style="color:var(--text2);margin-bottom:1.5rem">Todavía no has realizado ningún pedido.</p>
          <a href="/tienda" class="btn btn-primary">Ir a la tienda</a>
        </div>
      <% } %>
    </div>

    <% } %>

    <!-- Panel edición de datos propios (común a todos los roles) -->
    <div id="tab-editar" class="profile-panel hidden">
      <div style="display:grid;gap:1.5rem;grid-template-columns:1fr 1fr">

        <!-- Datos personales -->
        <div class="card" style="padding:2rem">
          <h3 style="margin-bottom:1.25rem">✏️ Mis datos personales</h3>
          <form action="/auth/perfil/editar" method="POST">
            <div class="form-group">
              <label class="form-label">Nombre</label>
              <input type="text" name="nombre" class="form-control" value="<%= persona.nombre %>" required>
            </div>
            <div class="form-group">
              <label class="form-label">Apellidos</label>
              <input type="text" name="apellidos" class="form-control" value="<%= persona.apellidos %>" required>
            </div>
            <div class="form-group">
              <label class="form-label">Teléfono</label>
              <input type="tel" name="telefono" class="form-control" value="<%= persona.telefono || '' %>" placeholder="600 000 000">
            </div>
            <div class="form-group" style="margin-bottom:1.5rem">
              <label class="form-label">Fecha de nacimiento</label>
              <input type="date" name="fechaNacimiento" class="form-control" value="<%= persona.fechaNacimiento ? new Date(persona.fechaNacimiento).toISOString().split('T')[0] : '' %>">
            </div>
            <p style="font-size:.8rem;color:var(--text2);margin-bottom:1rem">
              ⚠️ No puedes cambiar tu correo electrónico ni los datos de otras personas.
            </p>
            <button type="submit" class="btn btn-primary btn-full">Guardar cambios</button>
          </form>
        </div>

        <!-- Cambiar contraseña -->
        <div class="card" style="padding:2rem">
          <h3 style="margin-bottom:1.25rem">🔒 Cambiar contraseña</h3>
          <form action="/auth/perfil/password" method="POST">
            <div class="form-group">
              <label class="form-label">Contraseña actual</label>
              <input type="password" name="passwordActual" class="form-control" required>
            </div>
            <div class="form-group">
              <label class="form-label">Nueva contraseña</label>
              <input type="password" name="passwordNueva" class="form-control" minlength="8" required>
            </div>
            <div class="form-group" style="margin-bottom:1.5rem">
              <label class="form-label">Confirmar nueva contraseña</label>
              <input type="password" name="passwordConfirmar" class="form-control" minlength="8" required>
            </div>
            <button type="submit" class="btn btn-outline btn-full">Cambiar contraseña</button>
          </form>
        </div>

      </div>

      <!-- Datos del tutor legal (solo si es menor registrado con tutor) -->
      <% if (persona.tutorNombre) { %>
      <div class="card" style="padding:2rem;margin-top:1.5rem;border:2px solid rgba(var(--accent-rgb),.35)">
        <h3 style="margin-bottom:1.25rem;color:var(--accent)">👪 Datos del tutor legal</h3>
        <p style="font-size:.82rem;color:var(--text2);margin-bottom:1.25rem">
          Estos datos se recogieron en el momento del registro. Si necesitas modificarlos contacta con el club.
        </p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
          <div class="form-group" style="margin-bottom:0">
            <label class="form-label" style="font-size:.78rem">Nombre</label>
            <input type="text" class="form-control" value="<%= persona.tutorNombre %>" disabled>
          </div>
          <div class="form-group" style="margin-bottom:0">
            <label class="form-label" style="font-size:.78rem">Apellidos</label>
            <input type="text" class="form-control" value="<%= persona.tutorApellidos %>" disabled>
          </div>
          <div class="form-group" style="margin-bottom:0">
            <label class="form-label" style="font-size:.78rem">DNI</label>
            <input type="text" class="form-control" value="<%= persona.tutorDni %>" disabled>
          </div>
          <div class="form-group" style="margin-bottom:0">
            <label class="form-label" style="font-size:.78rem">Teléfono</label>
            <input type="text" class="form-control" value="<%= persona.tutorTelefono || '–' %>" disabled>
          </div>
          <% if (persona.tutorFechaNacimiento) { %>
          <div class="form-group" style="margin-bottom:0;grid-column:1/-1">
            <label class="form-label" style="font-size:.78rem">Fecha de nacimiento del tutor</label>
            <input type="text" class="form-control" value="<%= new Date(persona.tutorFechaNacimiento).toLocaleDateString('es') %>" disabled>
          </div>
          <% } %>
        </div>
      </div>
      <% } %>

    </div>
  </div>
</main>

<script>
// Abrir tab de edición si viene parámetro en la URL
if (window.location.hash === '#editar') {
  const btn = document.querySelector('[data-tab="editar"]');
  if (btn) btn.click();
}
</script>

<%- include('../partials/footer') %>
