<%- include('../partials/head', { title: 'Noticias' }) %>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<!-- Cabecera -->
<div class="page-header">
  <div class="container">
    <div class="breadcrumb">
      <a href="/">Inicio</a><span class="breadcrumb-sep">›</span>
      <span>Noticias</span>
    </div>
    <h1 class="page-header-title">Noticias del club</h1>
    <p class="page-header-desc">Mantente al día con todo lo que ocurre en el Club Béisbol Granollers.</p>
  </div>
</div>

<main>
  <div class="container section-py">
    <div class="news-layout">
      <!-- Artículos -->
      <div>
        <% if (typeof noticias !== 'undefined' && noticias && noticias.length > 0) { %>

          <!-- Destacada principal -->
          <% const dest = noticias.find(n => n.destacada) || noticias[0]; %>
          <a href="/noticias/<%= dest.id %>" class="card card-hover news-featured-grid" style="display:grid;grid-template-columns:280px 1fr;margin-bottom:2rem;text-decoration:none;overflow:hidden">
            <div style="overflow:hidden;min-height:200px">
              <% if (dest.imagen) { %>
                <img src="<%= dest.imagen %>" alt="<%= dest.titulo %>" style="width:100%;height:100%;object-fit:cover;display:block;<%= dest.imagen.includes('pitcher') ? 'object-position:center 20%' : '' %>">
              <% } else { %>
                <div style="width:100%;height:100%;min-height:200px;display:flex;align-items:center;justify-content:center;font-size:2.5rem;background:linear-gradient(135deg,var(--bg2),var(--bg3))">📰</div>
              <% } %>
            </div>
            <div class="news-body">
              <div class="news-meta">
                <span class="badge badge-primary badge-sm">Destacada</span>
                <span><%= new Date(dest.publicadoEn).toLocaleDateString('es',{day:'2-digit',month:'long',year:'numeric'}) %></span>
              </div>
              <h2 style="font-size:1.3rem;font-weight:800;margin-bottom:.75rem;line-height:1.3"><%= dest.titulo %></h2>
              <p class="news-excerpt"><%= dest.resumen %></p>
              <span class="news-link" style="margin-top:1rem;display:inline-flex">Leer artículo completo →</span>
            </div>
          </a>

          <!-- Resto de noticias -->
          <div class="news-grid">
            <% noticias.filter(n => n.id !== dest.id).forEach(function(noticia) { %>
              <a href="/noticias/<%= noticia.id %>" class="card news-card card-hover" style="text-decoration:none">
                <div class="news-thumb">
                  <% if (noticia.imagen) { %>
                    <img src="<%= noticia.imagen %>" alt="<%= noticia.titulo %>" style="<%= noticia.imagen.includes('pitcher') ? 'object-position:center 20%' : '' %>">
                  <% } else { %>
                    <div class="news-thumb-placeholder">📰</div>
                  <% } %>
                </div>
                <div class="news-body">
                  <div class="news-meta">
                    <span><%= new Date(noticia.publicadoEn).toLocaleDateString('es',{day:'2-digit',month:'short',year:'numeric'}) %></span>
                    <% if (noticia.destacada) { %><span class="badge badge-primary badge-sm">Destacada</span><% } %>
                  </div>
                  <h3 class="news-title"><%= noticia.titulo %></h3>
                  <p class="news-excerpt"><%= noticia.resumen %></p>
                  <span class="news-link">Leer más →</span>
                </div>
              </a>
            <% }) %>
          </div>

        <% } else { %>
          <div class="card" style="padding:4rem;text-align:center">
            <div style="font-size:3rem;margin-bottom:1rem">📰</div>
            <h3 style="margin-bottom:.5rem">Próximamente</h3>
            <p style="color:var(--text2)">Aún no hay noticias publicadas. Vuelve pronto.</p>
          </div>
        <% } %>
      </div>

      <!-- Sidebar -->
      <aside class="news-sidebar">
        <div class="card news-sidebar-card">
          <p class="news-sidebar-title">Noticias recientes</p>
          <% if (typeof noticias !== 'undefined' && noticias) { %>
            <% noticias.slice(0,5).forEach(function(n) { %>
              <a href="/noticias/<%= n.id %>" class="news-mini" style="text-decoration:none">
                <div class="news-mini-img">
                  <% if (n.imagen) { %>
                    <img src="<%= n.imagen %>" alt="">
                  <% } else { %>
                    <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--bg2)">📰</div>
                  <% } %>
                </div>
                <div class="news-mini-info">
                  <p class="news-mini-title"><%= n.titulo.length > 55 ? n.titulo.substring(0,55) + '…' : n.titulo %></p>
                  <span class="news-mini-date"><%= new Date(n.publicadoEn).toLocaleDateString('es',{day:'2-digit',month:'short'}) %></span>
                </div>
              </a>
            <% }) %>
          <% } %>
        </div>

        <div class="card news-sidebar-card">
          <p class="news-sidebar-title">Categorías</p>
          <div style="display:flex;flex-direction:column;gap:.4rem">
            <% const catNames = ['SUB10','SUB12','SUB14','SUB16','SUB18','SENIOR']; %>
            <% catNames.forEach(function(c) { %>
              <a href="/categorias/<%= c.toLowerCase() %>" style="display:flex;align-items:center;justify-content:space-between;padding:.5rem .75rem;border-radius:var(--radius-sm);color:var(--text2);font-size:.88rem;transition:all .2s">
                <span>⚾ <%= c %></span>
                <span style="font-size:.72rem;opacity:.5">→</span>
              </a>
            <% }) %>
          </div>
        </div>
      </aside>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
